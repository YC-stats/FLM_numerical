gAR_1=function(n,ln,decay,a0){###epsilon_i(u) -> AR(1) process
t=(1:n)/n
u=(1:ln)/ln
r=matrix(0,a0,n)
c1=0.5*cos(pi*t/3)#changed0.3*(t-0.5)^2
phi=diag(1,a0,a0)
phi[abs(row(phi)-col(phi))==1]=1/3
eps=matrix(rnorm(n*a0),a0,n)#sqrt(3/4)*matrix(rt(n*a0,8),a0,n) #a0*n
e=sweep(eps,1,decay,'*')
r[,1]=e[,1]
for (i in 2:n){
r[,i]=c1[i]*phi%*%r[,i-1]+e[,i]
}
basis_u=gene_Four(u,a0,ln)
epsilon=t(r)%*%basis_u
return(epsilon[51:n,])
}
