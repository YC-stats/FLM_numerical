berror=bseq[order(GCV)[1]]
bb[lit]=aa*berror
}else{berror=B_error;bb[lit]=aa*berror}
for(uu in 1:NN)
{
Estimat_FDA[,uu]= Curveestimate(GG$Data[,uu],b=bb[lit])
}
Estimat_FDA1=matrix(0,nrow=UU,ncol=NN)
for(uu in 1:NN)
{
Estimat_FDA1[,uu]= Curveestimate1(GG$Data[,uu],b=berror)
}
c_hat=mean(Estimat_FDA)
f_hat=apply(Estimat_FDA,1,mean)/c_hat
g_hat=apply(Estimat_FDA,2,mean)/c_hat
mu_n=c_hat*f_hat%*%t(g_hat)
max_dev=max(abs(Estimat_FDA[(1+floor(bb[lit]*UU)):
floor(UU-bb[lit]*UU),]-mu_n[(1+floor(bb[lit]*UU)):
floor(UU-bb[lit]*UU),]))*sqrt(bb[lit]*UU)/sqrt(2)
#max_dev=max(abs(Estimat_FDA[1: UU,]-GG$Signal[1: UU,]))*sqrt(bb*UU)/sqrt(2)
#GG$Signal
if(true.error=='T'){
Residual_Matrix=GG$Data-GG$Signal
}else{Residual_Matrix=GG$Data-Estimat_FDA1}
rm(GG)
Matrix_SCB=SCB_matrix(Residual_Matrix,b=bb[lit])
mm=M_select(y_matrix= Matrix_SCB, Mseq=Mseq,rep_time=NN)
Critical=HDtest((Matrix_SCB),m=mm,lit=boots,rep_time =NN)
#Critical=HDtest_Residual(Residual_Matrix,b=bb,m=mm,lit=boots,uu=1:UU/UU)##Could change uu
#rm(Matrix_SCB)
criti90=sort(Critical)[0.9*boots]
criti95=sort(Critical)[0.95*boots]
if(max_dev<=criti90){
level90=level90+1
width90[lit]=2*criti90*sqrt(2)/sqrt(UU*bb[lit])
}
if(max_dev<=criti95){
level95=level95+1
width95[lit]=2*criti95*sqrt(2)/sqrt(UU*bb[lit])
}
Tstat[lit]=max_dev;C90[lit]=criti90;C95[lit]=criti95;BB[lit]=berror;M_record[lit]=mm
}
