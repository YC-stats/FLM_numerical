source("gcv_lamb.R")
lamb_hat <- gcv_lamb(y,score,v,D)$lamb
x = score
c =v
P=D
n=length(y) #sample size
if (n==400){
l=seq(10^(-8),3*10^(-7),by=10^(-8))
#change to l=seq(10^(-9),2*10^(-8),by=10^(-9))
#when using legendre polynomials in MA case
}else if (n==800){
l=seq(10^(-8),2*10^(-5),by=10^(-8))
#change to l=seq(10^(-9),10^(-8),by=10^(-9))
#when using legendre polynomials in MA case
}
nn=length(l)
err_squ=rep(0,nn)
mean_squ=rep(0,nn)
#R=matrix(0,c,c)
the_hat=matrix(0,nrow=c,ncol=n)
for (k in 1:nn){
lamb=l[k]
R=lamb*P
H_hat=x[,1:c]%*%solve(t(x[,1:c])%*%x[,1:c]/n+
R)%*%t(x[,1:c])/n
err_squ[k]=mean(((diag(rep(1,n))-H_hat)%*%y)^2)/
(1-mean(diag(H_hat)))^2
}
plot(err_squ)
l=seq(10^(-10),2*10^(-8),by=10^(-10))
