set.seed(1)
data <- nycflights13::flights %>%
filter(dest == "PDX") %>% filter(arr_delay < 750)
mod <- lm(arr_delay~air_time+dep_delay*carrier,data)
data <- mod %>% get_regression_points()
data$arr_delay <- data$arr_delay_hat + rnorm(1341,0,sd=25)
data <- data %>% select(arr_delay,carrier,dep_delay,air_time)
data$carrier <- factor(data$carrier,levels=c("B6","DL","UA"),labels=c("JetBlue","Delta","United"))
rm(mod)
grid.arrange(ggplot(data,aes(x=arr_delay))+geom_histogram()+labs(title="Fig. 1")+theme_bw(),
ggplot(data,aes(x=carrier,y=arr_delay))+geom_boxplot()+labs(title="Fig. 2")+theme_bw(),
ggplot(data,aes(x=dep_delay,y=arr_delay))+geom_point(alpha=0.3)+labs(title="Fig. 3")+theme_bw(),
ggplot(data,aes(x=air_time,y=arr_delay))+geom_point(alpha=0.3)+labs(title="Fig. 4")+theme_bw(),nrow=2)
mod_1 <- lm(arr_delay ~ dep_delay, data)
get_regression_table(mod_1)
mod_2 <- lm(arr_delay ~ dep_delay + air_time + carrier, data)
get_regression_table(mod_2)
summary(mod_2)
mod_2 <- lm(arr_delay ~ dep_delay + air_time, data)
get_regression_table(mod_2)
