data.frame(
r.sq = summary(truck_log_mod)$r.sq,
rse = summary(truck_log_mod)$sigma) %>%
rbind(data.frame(
r.sq = summary(truck_mod)$r.sq,
rse = summary(truck_mod)$sigma))
)
